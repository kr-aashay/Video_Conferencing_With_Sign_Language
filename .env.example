# ══════════════════════════════════════════════════════════════════════════════
# HexaMinds — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Model paths ───────────────────────────────────────────────────────────────
MODEL_CKPT_PATH=checkpoints/best.pt
VOCAB_PATH=vocab.json

# ── Inference device: cpu | cuda | mps ────────────────────────────────────────
DEVICE=cpu

# ── Sliding window ────────────────────────────────────────────────────────────
WINDOW_SIZE=60
WINDOW_STRIDE=15
COOLDOWN_FRAMES=30

# ── Decoding ──────────────────────────────────────────────────────────────────
BEAM_WIDTH=5
SLM_CONFIDENCE=2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── SLM Refinement ────────────────────────────────────────────────────────────
# Set SLM_PROVIDER=ollama to enable Phi-3 refinement via local Ollama server.
# Steps: 1) Install https://ollama.com  2) ollama pull phi3
SLM_PROVIDER=ollama
OLLAMA_MODEL=phi3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_MS=200

# Confidence gate — Ollama is only called when Bi-LSTM certainty exceeds this
SLM_CONFIDENCE_GATE=0.8

# OpenAI-compatible alternative (leave blank to use Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
